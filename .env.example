# Backend server
PORT=4000

# CORS - comma separated origins allowed to call the API
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# --- Firestore (base de datos) ---
# Ruta a la clave de cuenta de servicio que descargaste en la consola de
# Firebase (Configuración del proyecto > Cuentas de servicio > Generar nueva
# clave privada). Guárdala FUERA de este repo. El project ID se infiere solo
# de la clave, no hace falta configurarlo aparte. Ver README para el paso a paso.
GOOGLE_APPLICATION_CREDENTIALS=C:/Users/tu-usuario/secrets/aviva-firebase-adminsdk.json

# --- Alternativa: emulador de Firestore (offline, requiere Java) ---
# Deja GOOGLE_APPLICATION_CREDENTIALS arriba comentado/vacío y descomenta esto
# para usar `npm run dev:emulator` en vez de `npm run dev` (ver README).
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# GCLOUD_PROJECT=app-campo-aviva

# --- DENUE (INEGI) real integration ---
# Get a token at https://www.inegi.org.mx/servicios/api_denue.html
DENUE_TOKEN=

# --- HubSpot real integration ---
# Create a Private App in HubSpot (Settings > Integrations > Private Apps) with
# these scopes: crm.objects.deals.read, crm.objects.deals.write,
# crm.objects.companies.read, crm.objects.owners.read, crm.schemas.deals.read,
# crm.schemas.deals.write (the last two are required to create/read the
# "aviva_service_owner" custom property — without them, Service owner never
# actually saves to HubSpot even though the token "works").
HUBSPOT_TOKEN=
# Your HubSpot account/portal ID (top right of the HubSpot UI, or Settings > Account Setup)
HUBSPOT_PORTAL_ID=
# Optional: the deals pipeline ID to sync against, if your account has more
# than one pipeline (Settings > Objects > Deals > Pipelines > pick one > the ID
# is in the URL). If unset, the app uses whichever pipeline the API returns
# first, which is only correct when there's a single pipeline.
HUBSPOT_PIPELINE_ID=
# The deals pipeline picked above MUST have stages named exactly (case
# insensitive): Documentos subidos, Documentos verificados, Aprobado,
# Contrato enviado, Desembolso, Rechazado — otherwise stage changes made in
# the admin app are silently not pushed to HubSpot.

# --- aviva-hr (directorio real de empleados, otro proyecto de Firebase) ---
# Permite importar vendedores reales desde aviva-hr en vez de darlos de alta a
# mano (ver "Rutas por vendedor" -> Sincronizar). El backend no tiene cuenta
# de servicio de ese proyecto, así que lee su REST API pública de Firestore
# (requiere que las reglas de Firestore de aviva-hr permitan lectura no
# autenticada de la colección `users`). Sin este valor, la sincronización
# simplemente se muestra como "No configurado" en el admin.
AVIVA_HR_PROJECT_ID=

# --- Uploads storage ---
# "disk" (default) writes to server/uploads. Set to "firebase" when running on
# Cloud Functions, where the filesystem is not persistent, and set the bucket below.
STORAGE_DRIVER=disk
FIREBASE_STORAGE_BUCKET=
