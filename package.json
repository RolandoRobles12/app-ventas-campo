{
  "name": "aviva-visitas-de-campo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev:server": "npm run dev -w server",
    "dev:seller": "npm run dev -w apps/seller",
    "dev:admin": "npm run dev -w apps/admin",
    "build": "npm run build -w server && npm run build -w apps/seller && npm run build -w apps/admin",
    "db:migrate": "npm run db:migrate -w server",
    "db:seed": "npm run db:seed -w server"
  },
  "engines": {
    "node": ">=20"
  }
}
