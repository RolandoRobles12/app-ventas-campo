# Variables de entorno para la Cloud Function `api` (2nd gen).
# Copia este archivo a functions/.env (o functions/.env.<project-id> para un
# proyecto específico) — Firebase las carga automáticamente en runtime.
# No necesitas STORAGE_DRIVER aquí: functions/src/index.ts ya fuerza "firebase".
# Tampoco necesitas credenciales de Firestore: en Cloud Functions el Admin SDK
# usa las credenciales del propio proyecto automáticamente.

CORS_ORIGINS=https://tu-site-vendedor.web.app,https://tu-site-admin.web.app

FIREBASE_STORAGE_BUCKET=tu-project-id.appspot.com

DENUE_TOKEN=
GOOGLE_MAPS_API_KEY=
HUBSPOT_TOKEN=
HUBSPOT_PORTAL_ID=
AVIVA_HR_PROJECT_ID=
