generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Producto {
  id         String   @id @default(cuid())
  nombre     String   @unique
  esDeCampo  Boolean  @default(false)
  giros      ProductoGiro[]
  vendedores Vendedor[]
  crmDeals   CrmDeal[]
}

model Giro {
  id        String          @id @default(cuid())
  nombre    String          @unique
  productos ProductoGiro[]
  vendedores VendedorGiro[]
}

model ProductoGiro {
  productoId String
  giroId     String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  giro       Giro     @relation(fields: [giroId], references: [id], onDelete: Cascade)

  @@id([productoId, giroId])
}

model Vendedor {
  id         String   @id @default(cuid())
  nombre     String
  iniciales  String
  color      String
  email      String?  @unique
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id])
  ciudad     String
  colonia    String?
  estado     String   @default("Activo") // Activo | Pausado
  drawZone   Boolean  @default(false)
  giros      VendedorGiro[]
  prospectos Prospecto[]
  visitas    Visita[]
  jornadas   Jornada[]
  metas      Meta[]
  dealsOwned CrmDeal[] @relation("dealOwner")
  createdAt  DateTime @default(now())
}

model VendedorGiro {
  vendedorId String
  giroId     String
  vendedor   Vendedor @relation(fields: [vendedorId], references: [id], onDelete: Cascade)
  giro       Giro     @relation(fields: [giroId], references: [id], onDelete: Cascade)

  @@id([vendedorId, giroId])
}

model Prospecto {
  id          String   @id @default(cuid())
  vendedorId  String
  vendedor    Vendedor @relation(fields: [vendedorId], references: [id], onDelete: Cascade)
  nombre      String
  direccion   String
  giro        String?
  distanciaKm Float?
  lat         Float?
  lng         Float?
  origen      String   @default("manual") // denue | manual
  estado      String   @default("por_visitar") // por_visitar | visitado
  telefono    String?
  createdAt   DateTime @default(now())
  visitas     Visita[]
}

model Visita {
  id             String    @id @default(cuid())
  prospectoId    String?
  prospecto      Prospecto? @relation(fields: [prospectoId], references: [id])
  vendedorId     String
  vendedor       Vendedor  @relation(fields: [vendedorId], references: [id])
  esNegocioNuevo Boolean   @default(false)
  nombreNegocio  String
  direccion      String
  resultado      String
  notas          String?
  fotoUrl        String?
  createdAt      DateTime  @default(now())
}

model Jornada {
  id              String    @id @default(cuid())
  vendedorId      String
  vendedor        Vendedor  @relation(fields: [vendedorId], references: [id])
  fecha           String    // YYYY-MM-DD
  horaEntrada     String?
  horaSalidaComer String?
  horaRegreso     String?
  horaSalida      String?
  activa          Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@unique([vendedorId, fecha])
}

model Meta {
  id           String   @id @default(cuid())
  vendedorId   String
  vendedor     Vendedor @relation(fields: [vendedorId], references: [id])
  tipo         String   // solicitudes_hoy | colocacion_mes
  periodo      String   // YYYY-MM-DD para dia, YYYY-MM para mes
  valorActual  Float    @default(0)
  valorMeta    Float

  @@unique([vendedorId, tipo, periodo])
}

model CrmDeal {
  id              String    @id @default(cuid())
  hubspotDealId   String?   @unique
  hubspotOwnerId  String?
  hubspotCompanyId String?
  cliente         String
  negocio         String
  productoId      String?
  producto        Producto? @relation(fields: [productoId], references: [id])
  etapa           String    @default("Documentos subidos")
  amount          Float?
  dealOwnerId     String?
  dealOwner       Vendedor? @relation("dealOwner", fields: [dealOwnerId], references: [id])
  dealOwnerLabel  String?
  serviceOwner    String?
  source          String    @default("local") // hubspot | local
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
}
